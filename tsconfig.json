/**
 * TypeScript 配置文件
 * 用于配置 TypeScript 编译选项
 * 
 * 包含以下配置：
 * - 目标 ECMAScript 版本
 * - 模块系统
 * - 严格类型检查
 * - Three.js 的类型定义
 */
{
    "compilerOptions": {
        // 目标 ECMAScript 版本，ES2020 与现代浏览器兼容
        "target": "ES2020",
        
        // 使用 ESNext 模块系统，支持 ES6+ 的 import/export 语法
        "module": "ESNext",
        
        // 启用严格类型检查，有助于发现潜在错误
        "strict": true,
        
        // 允许从没有默认导出的模块进行默认导入
        "allowSyntheticDefaultImports": true,
        
        // 使用 ES 模块互操作，解决 CommonJS 和 ES 模块的兼容性问题
        "esModuleInterop": true,
        
        // 不解析符号链接，遵循符号链接的实际路径
        "resolveJsonModule": true,
        
        // 跳过库检查，只检查用户代码的类型错误
        "skipLibCheck": true,
        
        // 模块解析策略，使用 Node 风格解析
        "moduleResolution": "bundler",
        
        // 强制一致使用单引号
        "jsx": "react",
        
        // 禁止使用 any 类型，需要显式声明类型
        "noImplicitAny": true,
        
        // 严格空值检查
        "strictNullChecks": true,
        
        // 生成 .d.ts 类型定义文件
        "declaration": true,
        
        // 源代码目录
        "sourceMap": true,
        
        // 输出目录
        "outDir": "./dist",
        
        // 根目录
        "rootDir": "."
    },
    // 包含的文件
    "include": [
        "*.ts"
    ],
    // 排除的文件
    "exclude": [
        "node_modules",
        "dist"
    ]
}
